POSTGRES_DB=hospitaldb
POSTGRES_USER=hospital
POSTGRES_PASSWORD=change-me
FRONTEND_PORT=8080
APP_JWT_SECRET=change-this-jwt-secret-before-deploying
APP_CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:8080
APP_PASSWORD_RESET_EXPIRATION_MS=3600000
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- AI (Groq) ---
# Get a key at https://console.groq.com/keys and put the value in your local .env (which is gitignored).
APP_AI_GROQ_API_KEY=gsk_your_key_here
APP_AI_GROQ_MODEL=llama-3.3-70b-versatile
APP_AI_GROQ_BASE_URL=https://api.groq.com/openai/v1
